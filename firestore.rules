rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all operations during development
    // WARNING: These rules are insecure and should be updated before production use
    match /{document=**} {
      allow read, write;
    }

    // More secure rules for future use:
    // Uncomment these and comment out the rule above when ready for production
    /*
    // Allow anyone to read and write to users collection
    match /users/{userId} {
      allow read, write;
    }

    // Allow anyone to read classes, but only authenticated users to write
    match /classes/{classId} {
      allow read;
      allow write;
    }

    // Allow anyone to read and write to game data collections
    match /fiscalGameData/{document=**} {
      allow read, write;
    }

    match /investmentGameData/{document=**} {
      allow read, write;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    */
  }
}
