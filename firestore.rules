rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read and write to users collection
    match /users/{userId} {
      allow read, write;
    }
    
    // Allow anyone to read classes, but only authenticated users to write
    match /classes/{classId} {
      allow read;
      allow write: if request.auth != null;
    }
    
    // Allow anyone to read and write to game data collections
    match /fiscalGameData/{document=**} {
      allow read, write;
    }
    
    match /investmentGameData/{document=**} {
      allow read, write;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
